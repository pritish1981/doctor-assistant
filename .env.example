# Copy to .env and fill in secrets before running docker compose or local dev.
# docker compose up --build

# --- Required ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Application ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8081
FRONTEND_PORT=3000

# --- Database (host port mapping; inside compose network use host "db") ---
DATABASE_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# --- OpenAI ---
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_TEMPERATURE=0.3
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# --- CORS (include Docker UI origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- RAG ---
RAG_CLASSPATH_DOCS_ENABLED=true
RAG_CLASSPATH_DOCS_AUTO_INGEST=true
RAG_TOP_K=5

# --- Frontend build args (docker compose) ---
VITE_DEFAULT_PATIENT_ID=b2000000-0000-4000-8000-000000000001

# --- MCP (optional) ---
MCP_ENABLED=false
MCP_CLIENT_ENABLED=false
